  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.160.0",
    "@vercel/node": "^5.6.11",
    "@vitejs/plugin-react": "^4.3.1",
    "geotiff": "^3.0.5",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0"
